{
  "version": 2,
  "framework": null,
  "routes": [
    {
      "src": "/blogs/(.*)/blog.md",
      "status": 404
    },
    {
      "src": "/(.*\\.(?:jpg|jpeg|png|gif|css|js|ico|woff|woff2|ttf|svg))",
      "dest": "/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/admin/approve_vendors.php(.*)",
      "dest": "/admin/approve_vendors.php"
    },
    {
      "src": "/blog-index.php(.*)",
      "dest": "/blog-index.php"
    },
    {
      "src": "/blog.php(.*)",
      "dest": "/blog.php"
    },
    {
      "src": "/contact.php(.*)",
      "dest": "/contact.php"
    },
    {
      "src": "/planner.php(.*)",
      "dest": "/planner.php"
    },
    {
      "src": "/profile.php(.*)",
      "dest": "/profile.php"
    },
    {
      "src": "/single-blog.php(.*)",
      "dest": "/single-blog.php"
    },
    {
      "src": "/single.php(.*)",
      "dest": "/single.php"
    },
    {
      "src": "/vendor_register.php(.*)",
      "dest": "/vendor_register.php"
    },
    {
      "src": "/vendors.php(.*)",
      "dest": "/vendors.php"
    },
    {
      "src": "/wedding_planner.php(.*)",
      "dest": "/wedding_planner.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ],
  "env": {
    "PHP_VERSION": "8.2"
  },
  "builds": [
    {
      "src": "/**/*.php",
      "use": "vercel-php@0.7.0",
      "config": {
        "includeFiles": {
          "Parsedown.php": true,
          "vendor/**": true
        }
      }
    },
    {
      "src": "/assets/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "/blogs/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "/firebase/**/*",
      "use": "@vercel/static"
    }
  ],
  "outputDirectory": "public"
}