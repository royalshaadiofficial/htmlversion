document.addEventListener('DOMContentLoaded', ()=>{ const btn = document.querySelector('.nav-toggle'); const nav = document.querySelector('.main-nav'); if(btn && nav) btn.addEventListener('click', ()=>{ nav.style.display = nav.style.display === 'flex' || nav.style.display === 'block' ? 'none' : 'flex'; nav.style.flexDirection='column'; }); });